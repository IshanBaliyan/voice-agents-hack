# Copy to .env and set absolute paths.
# `make download-model` populates <repo>/cactus_server/models/gemma-4-E4B-it,
# and the Makefile auto-points GEMMA4_MODEL_PATH there if this file is absent.
# Only set it explicitly if you want to load weights from somewhere else.
# GEMMA4_MODEL_PATH=/absolute/path/to/gemma-4-E4B-it

# Uncomment to point the model server at a different Cactus python checkout.
# Defaults to cactus_server/vendor/python.
# CACTUS_PYTHON_PATH=/absolute/path/to/cactus/python

# Relay → model-server WebSocket URL (rarely needs changing).
# CACTUS_MODEL_SERVER_URL=ws://localhost:8001/ws/cactus
